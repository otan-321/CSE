      "id": "vocab-confused-words",
      "title": "Commonly Confused Words",
      "type": "table",
      "headers": ["Words", "Distinction", "Example"],
      "rows": [
        ["a / an", "a before consonants; an before vowels", "a glass of water / an igloo"],
        ["accept / except", "accept = to take; except = excluding", "All except Daryl accepted a gift."],
        ["adverse / averse", "adverse = unfavorable; averse = unwilling", "The jury made an adverse decision. / She is risk-averse."],
        ["advice / advise", "advice = noun; advise = verb", "He asked for advice; his teacher advised him."],
        ["affect / effect", "affect = to influence (verb); effect = result (noun)", "The effects of malnutrition might affect their health."],
        ["oral / verbal", "oral = spoken; verbal = in words (spoken or written)", "—"],
        ["moral / morale", "moral = goodness/badness of actions; morale = state of spirits", "—"],
        ["noted / notorious", "noted = famous; notorious = infamous", "—"],
        ["stationary / stationery", "stationary = not moving (adj); stationery = writing materials (noun)", "—"],
        ["your / you're", "your = possessive; you're = you are", "Your water is on my table. / You're the person I love."]
